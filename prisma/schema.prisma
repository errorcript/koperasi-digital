// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Member {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String        // Hashed password
  role         String        @default("MEMBER")
  balance      Float         @default(0)
  points       Int           @default(0)
  transactions Transaction[]
  sessions     Session[]
  createdAt    DateTime      @default(now())
}

model Partner {
  id           String        @id @default(cuid())
  shopName     String
  email        String        @unique
  password     String        // Hashed password
  category     String
  address      String
  phone        String
  feePerTx     Float         @default(1000)
  status       String        @default("PENDING")
  products     Product[]
  transactions Transaction[]
  sessions     Session[]
  createdAt    DateTime      @default(now())
}

model Admin {
  id        String    @id @default(cuid())
  username  String    @unique
  password  String
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  member    Member?  @relation(fields: [userId], references: [id])
  partner   Partner? @relation(fields: [userId], references: [id])
  admin     Admin?   @relation(fields: [userId], references: [id])
}

model Product {
  id            String   @id @default(cuid())
  partner       Partner  @relation(fields: [partnerId], references: [id])
  partnerId     String
  name          String
  price         Float
  originalPrice Float?
  stock         Int      @default(50)
  image         String?
  createdAt     DateTime @default(now())
}

model Transaction {
  id           String   @id @default(cuid())
  member       Member   @relation(fields: [memberId], references: [id])
  memberId     String
  partner      Partner  @relation(fields: [partnerId], references: [id])
  partnerId    String
  totalAmount  Float
  adminFee     Float
  pointsEarned Int
  status       String   @default("SUCCESS")
  createdAt    DateTime @default(now())
}
